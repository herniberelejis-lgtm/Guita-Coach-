# ── Requerido siempre ──────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-algo-largo-y-aleatorio

# ── Claude API (clasificación IA) ──────────────────────────────────
# Obtener en: console.anthropic.com → API Keys
CLAUDE_API_KEY=

# ── Gmail OAuth ─────────────────────────────────────────────────────
# Obtener en: console.cloud.google.com
# 1. Crear proyecto → Habilitar Gmail API
# 2. Credenciales → OAuth 2.0 → Web → redirect: http://localhost:8000/api/auth/gmail/callback
# 3. Descargar JSON y guardarlo como google_credentials.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Mercado Pago OAuth ───────────────────────────────────────────────
# Obtener en: developers.mercadopago.com → Tu aplicación
# Redirect URI: http://localhost:8000/api/auth/mp/callback
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# ── Config de la app ────────────────────────────────────────────────
APP_URL=http://localhost:8000
PORT=8000
DEMO_MODE=true
