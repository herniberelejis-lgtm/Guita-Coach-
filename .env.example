# ── Requerido siempre ──────────────────────────────────────────────
# Generá un valor aleatorio fuerte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Claude API (clasificación IA) ──────────────────────────────────
# Obtener en: console.anthropic.com → API Keys
CLAUDE_API_KEY=

# ── Gmail OAuth ─────────────────────────────────────────────────────
# Obtener en: console.cloud.google.com
# 1. Crear proyecto → Habilitar Gmail API
# 2. Credenciales → OAuth 2.0 → Web → redirect: {APP_URL}/api/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Mercado Pago OAuth ───────────────────────────────────────────────
# Obtener en: developers.mercadopago.com → Tu aplicación
# Redirect URI: {APP_URL}/api/auth/mp/callback
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# ── Gemini API ───────────────────────────────────────────────────────
# Obtener en: aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Config de la app ────────────────────────────────────────────────
APP_URL=http://localhost:8000
PORT=8000
DEMO_MODE=false
AI_PROVIDER=gemini
